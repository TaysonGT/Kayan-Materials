# Kayan Materials - Environment Configuration
# Copy to .env and update values for your environment

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (update with your MySQL credentials)
DATABASE_HOST=localhost
DATABASE_PORT=21756
DATABASE_NAME=kayan
DATABASE_USERNAME=user
DATABASE_PASSWORD=password

# CORS Configuration - Frontend URL
FRONTEND_URL=http://localhost:5173

# API Routing
# All API endpoints are under /api prefix for security and organization
# Example: /api/materials, /api/suppliers, /api/transactions
# Development: Vite proxy intercepts /api/* and forwards to backend
# Production: Netlify/server routing handles /api redirect

